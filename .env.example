# Replace every example secret before enabling authentication. Never commit a real .env file.
SIMULOOM_AUTH_ENABLED=true
SIMULOOM_API_KEYS={"replace-viewer-key":{"subject":"reviewer","role":"viewer"},"replace-operator-key":{"subject":"qa-engineer","role":"operator"},"replace-admin-key":{"subject":"platform-owner","role":"admin"}}
SIMULOOM_AUDIT_SIGNING_KEY=replace-with-a-long-random-secret
SIMULOOM_PLATFORM_DB=workspace/runtime/platform.db
SIMULOOM_INTEGRATION_ALLOWED_HOSTS=hooks.example.com
SIMULOOM_INTEGRATION_SIGNING_KEY=replace-with-a-long-random-secret
SIMULOOM_INTEGRATION_ALLOW_HTTP=false
SIMULOOM_SECRETS_MASTER_KEY=replace-with-at-least-32-random-characters
# Optional local-only AI draft assistant. It never saves or deploys generated scenarios.
SIMULOOM_AI_ENABLED=false
SIMULOOM_AI_BASE_URL=http://localhost:11434
SIMULOOM_AI_MODEL=qwen3:8b
SIMULOOM_RUNTIME=wiremock
WIREMOCK_URL=http://localhost:8080
# For SIMULOOM_RUNTIME=native, set the externally reachable service base URL if needed.
SIMULOOM_NATIVE_RUNTIME_URL=http://localhost:8000/runtime
SIMULOOM_NATIVE_RUNTIME_STORE=sqlite
SIMULOOM_NATIVE_RUNTIME_DB=workspace/runtime/native.db
SIMULOOM_NATIVE_JOURNAL_LIMIT=1000
